{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=movix_core;Username=movix;Password=movix_secret;Include Error Detail=true",
    "Redis": "redis:6379"
  },
  "Outbox": {
    "Enabled": true,
    "PollIntervalMs": 500,
    "MaxBatchSize": 50,
    "ErrorBackoffMs": 2000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Information",
      "Movix": "Information",
      "Movix.Infrastructure.Persistence": "Information"
    }
  }
}
